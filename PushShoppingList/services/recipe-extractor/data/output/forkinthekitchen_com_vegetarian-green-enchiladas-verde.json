  "instructions": [
    {
      "section": null,
      "step_number": 1,
      "instruction": "Preheat oven to 350F. Spread 1 cup of enchilada sauce across the bottom of a 9x13 baking dish. Set aside.",
      "temperature": null,
      "time": null,
      "equipment_used": [
        "oven"
      ]
    },
    {
      "section": null,
      "step_number": 2,
      "instruction": "Drain and rinse the jackfruit, then use your hands to break it apart to \"shred\" it. Roughly chop or break apart the firm base; any \"seeds\" are fine to use as they are.",
      "temperature": null,
      "time": null,
      "equipment_used": [
        "cutting board",
        "knife"
      ]
    },
    {
      "section": null,
      "step_number": 3,
      "instruction": "In a large mixing bowl, combine shredded jackfruit, white beans, green chiles, 1 cup shredded cheese, cumin, cilantro, and salt.",
      "temperature": null,
      "time": null,
      "equipment_used": [
        "mixing bowl"
      ]
    },
    {
      "section": null,
      "step_number": 4,
      "instruction": "Warm tortillas as needed; if using corn tortillas wrap in a damp paper towel and microwave for 30 seconds, or lightly fry each side in a little oil before wrapping.",
      "temperature": null,
      "time": null,
      "equipment_used": []
    },
    {
      "section": null,
      "step_number": 5,
      "instruction": "Place a tortilla flat on a work surface, and place approximately ⅓ cup of filling in the center. Take one edge of the tortilla and roll it around the filling. Place the rolled tortilla in the baking dish, seam side down. Continue until all enchiladas are formed.",
      "temperature": null,
      "time": null,
      "equipment_used": [
        "rolling pin"
      ]
    },
    {
      "section": null,
      "step_number": 6,
      "instruction": "Spread the remaining sauce across the tortillas (using 1 to 1 ½ cups depending on how saucy you like them). Sprinkle the remaining cheese across the top.",
      "temperature": null,
      "time": null,
      "equipment_used": []
    },
    {
      "section": null,
      "step_number": 7,
      "instruction": "Bake for 25-30 minutes until bubbly and the cheese is melted. Broil for 1-2 minutes for extra golden cheese. Let the enchiladas rest for 5-10 minutes before serving.",
      "temperature": null,
      "time": null,
      "equipment_used": [
        "oven"
      ]
    },
    {
      "section": null,
      "step_number": 8,
      "instruction": "Garnish with extra cilantro, red onion, avocado, or sour cream as desired. Enjoy!",

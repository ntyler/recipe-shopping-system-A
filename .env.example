# Copy this file to .env for local development.
# Never commit real API keys, service account JSON, SMTP passwords, cookies, or user data.

# Flask/runtime
SHOPPING_APP_SECRET_KEY=replace-with-random-local-secret
SHOPPING_APP_PORT=5083
SHOPPING_APP_SERVER=waitress
SHOPPING_APP_PYTHON_EXE=C:\Python39\python.exe
SHOPPING_APP_ADMIN_EMAIL=admin@example.com
SHOPPING_APP_SUPPORT_EMAIL=support@example.com
SHOPPING_APP_SUPPORT_ADMIN_EMAILS=admin@example.com

# OpenAI
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_RECIPE_MODEL=gpt-4o-mini
OPENAI_MENU_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_ADDRESS_MODEL=gpt-4o-mini
OPENAI_COOKBOOK_ITEM_MODEL=gpt-4o-mini

# Recipe title images
TITLE_IMAGE_PROVIDER=comfyui
TITLE_IMAGE_FALLBACK_PROVIDER=none
OLLAMA_URL=http://localhost:11434
OLLAMA_PROMPT_MODEL=qwen2.5:7b
COMFYUI_URL=http://127.0.0.1:8188

# Firebase web app config
FIREBASE_API_KEY=replace-with-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your-sender-id
FIREBASE_APP_ID=your-web-app-id
FIREBASE_MEASUREMENT_ID=your-measurement-id

# Firebase Admin SDK: use one of these locally, never both in a committed file.
FIREBASE_SERVICE_ACCOUNT_PATH=C:\path\to\firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudflare R2 PDF sharing
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ENDPOINT=https://your-cloudflare-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_BASE_URL=https://your-public-r2-domain.example
DELETE_LOCAL_PDF_AFTER_UPLOAD=0

# SMTP/email workflows
SHOPPING_APP_SMTP_HOST=smtp.example.com
SHOPPING_APP_SMTP_PORT=587
SHOPPING_APP_SMTP_USERNAME=user@example.com
SHOPPING_APP_SMTP_PASSWORD=replace-with-smtp-app-password
SHOPPING_APP_SMTP_FROM_EMAIL=support@example.com
SHOPPING_APP_SMTP_FROM_NAME=Recipe Shopping System
SHOPPING_APP_SMTP_USE_TLS=1
SHOPPING_APP_PASSWORD_RESET_BASE_URL=https://your-app-domain.example
SHOPPING_APP_ACCOUNT_LINK_BASE_URL=https://your-app-domain.example

# Background jobs
REDIS_URL=redis://localhost:6379/0
WORKER_QUEUES=ai-pantry-menu,ai-pantry-recipe,ai-pantry-media,ai-pantry-product,ai-pantry-light
SHOPPING_APP_JOBS_DB=instance\jobs.sqlite3

# Optional notifications
NTFY_TOPIC=replace-with-private-ntfy-topic
SHOPPING_APP_NTFY_TOPIC_PREFIX=shopping-user
SHOPPING_APP_WEB_PUSH_PUBLIC_KEY=
VAPID_PUBLIC_KEY=

# Optional data path overrides
SHOPPING_APP_USERS_FILE=PushShoppingList\users.json
SHOPPING_APP_AVATAR_UPLOAD_DIR=PushShoppingList\static\uploads\avatars
ACCESS_DB_PATH=C:\path\to\legacy.accdb
SQLITE_DB_PATH=instance\shopping.sqlite3
